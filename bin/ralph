#!/bin/bash

# Ralph CLI - Autonomous AI coding loop
# Runs OpenCode with the Ralph prompt for autonomous feature implementation

set -e

# Default values
MAX_ITERATIONS=10

usage() {
  cat <<EOF
Usage: ralph [options]

Options:
  --max-iterations N   Maximum number of iterations to run (default: 10)
  -h, --help           Show this help message

Ralph is an autonomous AI coding agent that iteratively processes
user stories from prd.json until completion.

Requirements:
  - prd.json file in the current directory
  - OpenCode installed and configured
  - Ralph prompt installed at ~/.config/opencode/ralph.md
  - Git repository with proper setup
EOF
}

error() {
  printf 'Error: %s\n' "$1" >&2
}

# Parse command line options
while [[ $# -gt 0 ]]; do
  case $1 in
    --max-iterations)
      if [[ -z "$2" ]]; then
        error "--max-iterations requires a value"
        printf "Use 'ralph --help' for usage information.\n" >&2
        exit 1
      fi
      if [[ ! "$2" =~ ^[1-9][0-9]*$ ]]; then
        error "--max-iterations must be a positive integer"
        exit 1
      fi
      MAX_ITERATIONS="$2"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      error "unknown option or argument: $1"
      printf "Use 'ralph --help' for usage information.\n" >&2
      exit 1
      ;;
  esac
done

# Check if prd.json exists
if [[ ! -f "prd.json" ]]; then
  error "prd.json not found in current directory"
  printf 'Use the /ralph command in OpenCode to create prd.json from a PRD.\n' >&2
  exit 1
fi

# Check if opencode is available
if ! command -v opencode >/dev/null 2>&1; then
  error "opencode command not found"
  printf 'Please install OpenCode first: https://opencode.ai/install\n' >&2
  exit 1
fi

# Set environment variable for max iterations
export RALPH_MAX_ITERATIONS="$MAX_ITERATIONS"

# Check if ralph.md exists in the installed location
RALPH_PROMPT_FILE="$HOME/.config/opencode/ralph.md"
if [[ ! -f "$RALPH_PROMPT_FILE" ]]; then
  error "$RALPH_PROMPT_FILE not found"
  printf "Please run 'make install' to set up the Ralph configuration.\n" >&2
  exit 1
fi

# Create prompt material in the current project so OpenCode does not need
# external-directory access during autonomous target-repository runs.
TEMP_PROMPT_FILE="$(mktemp "./.ralph-prompt.XXXXXX.md")"
cleanup_prompt_file() {
  rm -f "$TEMP_PROMPT_FILE"
}
trap cleanup_prompt_file EXIT

sed "s/\$MAX_ITERATIONS/$MAX_ITERATIONS/g" "$RALPH_PROMPT_FILE" > "$TEMP_PROMPT_FILE"

echo "Starting Ralph autonomous AI loop..."
echo "Using Ralph prompt from $RALPH_PROMPT_FILE"
echo ""

ITERATION=0
while [ $ITERATION -lt $MAX_ITERATIONS ]; do
  echo "Iteration $((ITERATION + 1)) of $MAX_ITERATIONS"

  # Run OpenCode with the processed prompt file
  opencode run -m openai/gpt-5.5 "$(cat "$TEMP_PROMPT_FILE")"

  ITERATION=$((ITERATION + 1))

  # Check if all user stories pass
  if ! grep -q '"passes": false' prd.json; then
    echo "All user stories completed."
    break
  fi
done

if [ $ITERATION -ge $MAX_ITERATIONS ]; then
  echo "Reached maximum iterations ($MAX_ITERATIONS) without completing all stories."
fi
